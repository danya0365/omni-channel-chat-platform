{
  "_comment": "TEMPLATE — คัดลอกเป็น .mcp.json (ถูก gitignore) แล้วตั้ง GITHUB_TOKEN ใน .claude/settings.local.json ก่อนใช้ ดู SETUP.md",
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}

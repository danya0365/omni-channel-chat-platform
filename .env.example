# คัดลอกเป็น .env (gitignore แล้ว) — ห้าม commit ค่าจริง / secret ของช่องทาง
# Postgres (ตรงกับ docker-compose.yml)
DATABASE_URL=postgres://omni:omni_dev_only@localhost:5432/omni

# apps/api
PORT=3001

# Channel secrets (เพิ่มเมื่อทำ channel นั้นๆ — เก็บใน .env เท่านั้น ห้าม hardcode)
# LINE_CHANNEL_SECRET=
# LINE_CHANNEL_ACCESS_TOKEN=
